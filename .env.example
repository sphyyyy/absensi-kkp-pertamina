# Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=ganti-dengan-secret-key-yang-kuat-minimal-32-karakter

# Database
DATABASE_URL=sqlite:///absensi_kkp.db

# Geofence - PT. Pertamina Patra Niaga Regional Sulawesi
GEOFENCE_LATITUDE=-5.1477
GEOFENCE_LONGITUDE=119.4327
GEOFENCE_RADIUS_METERS=100

# Waktu Absensi (format HH:MM, zona WITA UTC+8)
CHECKIN_START=07:00
CHECKIN_END=09:00
CHECKOUT_START=16:00
CHECKOUT_END=18:00

# Upload
MAX_UPLOAD_SIZE_MB=5
UPLOAD_FOLDER=uploads/selfies

# Session
SESSION_LIFETIME_MINUTES=480
